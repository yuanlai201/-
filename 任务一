// ==================== 各功能执行函数 ====================
void arithmetic_handler() {
    int choice;
    while (1) {
        arithmetic_menu();
        if (scanf("%d", &choice) != 1) {
            clear_input();
            printf("输入无效，请重新选择。\n");
            continue;
        }
        clear_input();
        if (choice == 0) break;
        double a, b, result;
        int valid = 1;
        switch (choice) {
            case 1: // 加法
                a = read_double("请输入 a: ");
                if (isnan(a)) break;
                b = read_double("请输入 b: ");
                if (isnan(b)) break;
                result = add(a, b);
                printf("结果: %.6g + %.6g = %.6g\n", a, b, result);
                break;
            case 2: // 减法
                a = read_double("请输入 a: ");
                if (isnan(a)) break;
                b = read_double("请输入 b: ");
                if (isnan(b)) break;
                result = sub(a, b);
                printf("结果: %.6g - %.6g = %.6g\n", a, b, result);
                break;
            case 3: // 乘法
                a = read_double("请输入 a: ");
                if (isnan(a)) break;
                b = read_double("请输入 b: ");
                if (isnan(b)) break;
                result = mul(a, b);
                printf("结果: %.6g * %.6g = %.6g\n", a, b, result);
                break;
            case 4: // 除法
                a = read_double("请输入 a: ");
                if (isnan(a)) break;
                b = read_double("请输入 b: ");
                if (isnan(b)) break;
                result = div_func(a, b);
                if (!isnan(result))
                    printf("结果: %.6g / %.6g = %.6g\n", a, b, result);
                break;
            case 5: // 取余
                a = read_double("请输入 a: ");
                if (isnan(a)) break;
                b = read_double("请输入 b: ");
                if (isnan(b)) break;
                result = mod_func(a, b);
                if (!isnan(result))
                    printf("结果: %.6g %% %.6g = %.6g\n", a, b, result);
                break;
            case 6: // 倒数
                a = read_double("请输入 a: ");
                if (isnan(a)) break;
                result = inv(a);
                if (!isnan(result))
                    printf("结果: 1 / %.6g = %.6g\n", a, result);
                break;
            default:
                printf("无效选项！\n");
                valid = 0;
        }
        if (valid) pause();
    }
}
void power_handler() {
    double base = read_double("请输入底数: ");
    if (isnan(base)) return;
    double exp = read_double("请输入指数: ");
    if (isnan(exp)) return;
    double result = power(base, exp);
    printf("结果: %.6g ^ %.6g = %.6g\n", base, exp, result);
    pause();
}
void trig_handler() {
    int choice;
    while (1) {
        trig_menu();
        if (scanf("%d", &choice) != 1) {
            clear_input();
            printf("输入无效，请重新选择。\n");
            continue;
        }
        clear_input();
        if (choice == 0) break;
        double angle, result;
        switch (choice) {
            case 1:
                angle = read_double("请输入角度 θ (度): ");
                if (isnan(angle)) break;
                result = sin_deg(angle);
                if (!isnan(result))
                    printf("sin(%.6g°) = %.6g\n", angle, result);
                break;
            case 2:
                angle = read_double("请输入角度 θ (度): ");
                if (isnan(angle)) break;
                result = cos_deg(angle);
                if (!isnan(result))
                    printf("cos(%.6g°) = %.6g\n", angle, result);
                break;
            case 3:
                angle = read_double("请输入角度 θ (度): ");
                if (isnan(angle)) break;
                result = tan_deg(angle);
                if (!isnan(result))
                    printf("tan(%.6g°) = %.6g\n", angle, result);
                break;
            default:
                printf("无效选项！\n");
        }
        pause();
    }
}
void pi_handler() {
    double pi = get_pi();
    printf("圆周率 π = %.15g\n", pi);
    pause();
}
void factorial_handler() {
    int n = read_int("请输入非负整数 n: ");
    if (n < 0) {
        printf("输入无效！\n");
        pause();
        return;
    }
    double result = factorial(n);
    if (!isnan(result)) {
        if (n <= 20)
            printf("%d! = %.0f\n", n, result);
        else
            printf("%d! = %.6e (科学计数法)\n", n, result);
    }
    pause();
}
// ==================== 主程序 ====================
int main() {
    int choice;
    while (1) {
        main_menu();
        if (scanf("%d", &choice) != 1) {
            clear_input();
            printf("输入无效，请重新选择。\n");
            continue;
        }
        clear_input();
        switch (choice) {
            case 0:
                printf("感谢使用，再见！\n");
                exit(0);
            case 1:
                arithmetic_handler();
                break;
            case 2:
                power_handler();
                break;
            case 3:
                trig_handler();
                break;
            case 4:
                pi_handler();
                break;
            case 5:
                factorial_handler();
                break;
            default:
                printf("无效选项，请重新选择。\n");
                pause();
        }
    }
    return 0;
}
