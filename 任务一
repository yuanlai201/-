#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <ctype.h>
// 清空输入缓冲区
void clear_input() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}
// 暂停并等待回车
void pause() {
    printf("\n按回车键继续...");
    clear_input();
    getchar();
}
// ==================== 运算函数模块 ====================
// 加法
double add(double a, double b) {
    return a + b;
}
// 减法
double sub(double a, double b) {
    return a - b;
}
// 乘法
double mul(double a, double b) {
    return a * b;
}
// 除法
double div_func(double a, double b) {   // 避免与 stdlib.h 中的 div 冲突
    if (b == 0) {
        printf("错误：除数不能为零！\n");
        return NAN;
    }
    return a / b;
}
// 取余（针对整数运算，但这里用double取模，仅在整数时有效）
double mod_func(double a, double b) {
    if (b == 0) {
        printf("错误：取余不能为零！\n");
        return NAN;
    }
    return fmod(a, b);
}
// 倒数
double inv(double a) {
    if (a == 0) {
        printf("错误：0 没有倒数！\n");
        return NAN;
    }
    return 1.0 / a;
}
// 幂运算
double power(double base, double exp) {
    return pow(base, exp);
}
// 正弦（角度制）
double sin_deg(double deg) {
    return sin(deg * M_PI / 180.0);
}
// 余弦（角度制）
double cos_deg(double deg) {
    return cos(deg * M_PI / 180.0);
}
// 正切（角度制）
double tan_deg(double deg) {
    double rad = deg * M_PI / 180.0;
    double t = tan(rad);
    if (fabs(t) > 1e15) {
        printf("错误：该角度正切值不存在（接近无穷大）\n");
        return NAN;
    }
    return t;
}
// 求π
double get_pi() {
    return M_PI;
}
// 阶乘（整数，使用double避免大数溢出）
double factorial(int n) {
    if (n < 0) {
        printf("错误：阶乘要求 n ≥ 0\n");
        return NAN;
    }
    if (n > 170) {
        printf("错误：数值过大，超出double表示范围\n");
        return NAN;
    }
    double result = 1.0;
    for (int i = 2; i <= n; i++) {
        result *= i;
    }
    return result;
}
// ==================== 输入辅助函数 ====================
// 读取一个double值，若失败则返回NAN并提示
double read_double(const char* prompt) {
    double val;
    printf("%s", prompt);
    if (scanf("%lf", &val) != 1) {
        clear_input();
        printf("输入无效，请重新输入。\n");
        return NAN;
    }
    clear_input();
    return val;
}
// 读取一个整数，若失败则返回-1（适用于阶乘）
int read_int(const char* prompt) {
    int val;
    printf("%s", prompt);
    if (scanf("%d", &val) != 1) {
        clear_input();
        printf("输入无效，请重新输入。\n");
        return -1;
    }
    clear_input();
    return val;
}
